.{
    // Package identifier within the Zig package namespace.
    .name = .glint,

    // Semantic version. Pre-1.0; minor bumps may break the cart format.
    // Cart manifests pin `min_engine` to refuse loading on older engines.
    .version = "0.0.1",

    // Globally unique package fingerprint. Generated by Zig on first
    // `zig init`; do not change. Forking conventions: regenerate ONLY when
    // the upstream project is unmaintained, otherwise the fork is hostile.
    .fingerprint = 0x77d017589e81e056, // Changing this has security and trust implications.

    // Earliest Zig version supported. We ride 0.16 stable; bump as needed.
    .minimum_zig_version = "0.16.0",

    // Dependencies will be added as features come online:
    //   - sokol-zig    (W1)  : window / GPU / audio / input
    //   - ziglua       (W5)  : Luau VM + sandbox
    //   - zflecs       (W7+) : ECS via flecs C
    //   - lodepng      (W6)  : single-header PNG IO for cart steganography
    //   - libxmp       (W7)  : .it tracker player
    //   - llama.cpp    (W9)  : NOT vendored; dlopened at runtime
    //   - GekkoNet     (v1.5): rollback netcode
    .dependencies = .{
        .sokol = .{
            .url = "git+https://github.com/floooh/sokol-zig#6ca71321c91e842fb32a8140802a546e50d8a086",
            .hash = "sokol-0.1.0-pb1HK9lgNwAAB5SLJlpJQ09PZ2CVydxkNs0KaptLaTUD",
        },
    },
    .paths = .{
        "build.zig",
        "build.zig.zon",
        "src",
        "vendor",
        "LICENSE",
        "README.md",
        "CLAUDE.md",
    },
}
